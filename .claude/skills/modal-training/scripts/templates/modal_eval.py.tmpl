"""Eval on Modal — generated by the modal-training skill.

Generated for experiment: ${EXP_ID}

Loads a trained adapter from the checkpoint volume, runs inference on a held-out
set, writes metrics to /ckpts/eval_results.json. Customize the body of `eval_fn`
for your task.

Run:
    modal run --env=neurico-${EXP_ID} <this file> \\
        2>&1 | tee logs/modal_eval_$$(date +%Y%m%d_%H%M%S).log
"""
from __future__ import annotations

import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

import modal

# lifecycle.py only exists in the local workspace; if the import fails we're
# inside the Modal container. See lora-train template for the rationale.

EXP_ID      = "${EXP_ID}"
DATA_VOLUME = "${DATA_VOLUME}"
CKPT_VOLUME = "${CKPT_VOLUME}"
HF_VOLUME   = "${HF_VOLUME}"

try:
    sys.path.insert(0, str(Path(".claude/skills/modal-training/scripts")))
    import lifecycle  # noqa: E402
except ImportError:
    lifecycle = None  # type: ignore[assignment]

SHARE_HF_CACHE = ${SHARE_HF_CACHE}

if lifecycle is not None:
    PULL_MANIFEST = [
        {"from_volume": CKPT_VOLUME, "from": "/eval_config.json",
         "to": "artifacts/eval_config.json", "required": True},
        {"from_volume": CKPT_VOLUME, "from": "/eval_results.json",
         "to": "artifacts/eval_results.json", "required": True},
    ]
    lifecycle.register(
        EXP_ID,
        volumes=[DATA_VOLUME, CKPT_VOLUME] + ([] if SHARE_HF_CACHE else [HF_VOLUME]),
        apps=[],
        required_secrets=${REQUIRED_SECRETS},
        pull_manifest=PULL_MANIFEST,
        share_hf_cache=SHARE_HF_CACHE,
    )

MODEL_NAME     = "${BASE_MODEL}"
MODEL_REVISION = "${BASE_MODEL_REVISION}"
MINUTES        = 60

eval_image = (
    modal.Image.from_registry("nvidia/cuda:12.4.0-devel-ubuntu22.04",
                              add_python="3.11")
    .entrypoint([])
    .uv_pip_install(
        "torch==2.5.1",
        "transformers==4.46.3",
        "peft==0.13.2",
        "accelerate==1.1.1",
        "huggingface_hub[hf_transfer]",
        "sentencepiece",
    )
    .env({"HF_HUB_ENABLE_HF_TRANSFER": "1"})
)

hf_cache_vol = modal.Volume.from_name(HF_VOLUME,   create_if_missing=True)
data_vol     = modal.Volume.from_name(DATA_VOLUME, create_if_missing=True)
ckpt_vol     = modal.Volume.from_name(CKPT_VOLUME, create_if_missing=True)

app = modal.App("${APP_NAME}")


@app.function(
    image=eval_image,
    gpu="${GPU}",
    timeout=2 * 60 * MINUTES,
    secrets=${SECRETS_LIST},
    volumes={
        "/root/.cache/huggingface": hf_cache_vol,
        "/data":  data_vol,
        "/ckpts": ckpt_vol,
    },
)
def eval_fn(
    adapter_dir: str = "/ckpts/final",
    eval_file: str = "${VAL_FILE}",
    max_new_tokens: int = 256,
    n_examples: int = 100,
) -> dict:
    """Run inference + metric capture. Customize for the task."""
    import torch
    from transformers import AutoModelForCausalLM, AutoTokenizer
    from peft import PeftModel

    started_at = datetime.now(timezone.utc).isoformat(timespec="seconds")

    Path("/ckpts").mkdir(parents=True, exist_ok=True)
    eval_config = {
        "exp_id": "${EXP_ID}",
        "stage": "eval",
        "base_model": MODEL_NAME,
        "base_model_revision": MODEL_REVISION,
        "adapter_dir": adapter_dir,
        "eval_file": eval_file,
        "n_examples": n_examples,
        "max_new_tokens": max_new_tokens,
        "started_at": started_at,
    }
    with open("/ckpts/eval_config.json", "w", encoding="utf-8") as fh:
        json.dump(eval_config, fh, indent=2)
    ckpt_vol.commit()

    tok = AutoTokenizer.from_pretrained(MODEL_NAME, use_fast=True)
    if tok.pad_token is None:
        tok.pad_token = tok.eos_token

    base = AutoModelForCausalLM.from_pretrained(
        MODEL_NAME,
        revision=MODEL_REVISION,
        torch_dtype=torch.bfloat16,
        device_map="auto",
    )
    if Path(adapter_dir).exists():
        model = PeftModel.from_pretrained(base, adapter_dir)
        adapter_used = True
    else:
        model = base
        adapter_used = False
    model.eval()

    results = []
    with open(eval_file, encoding="utf-8") as fh:
        for i, line in enumerate(fh):
            if i >= n_examples:
                break
            row = json.loads(line)
            prompt = tok.apply_chat_template(
                row["messages"][:-1], tokenize=False, add_generation_prompt=True,
            )
            target = row["messages"][-1]["content"]
            inputs = tok(prompt, return_tensors="pt").to(model.device)
            with torch.no_grad():
                out = model.generate(
                    **inputs, max_new_tokens=max_new_tokens, do_sample=False,
                )
            pred = tok.decode(out[0][inputs.input_ids.shape[1]:],
                              skip_special_tokens=True)
            results.append({"prompt": prompt[:200], "target": target[:200],
                            "pred": pred[:200]})

    summary = {
        "exp_id": "${EXP_ID}",
        "base_model": MODEL_NAME,
        "adapter_dir": adapter_dir if adapter_used else None,
        "n_examples": len(results),
        "started_at": started_at,
        "completed_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
    }
    with open("/ckpts/eval_results.json", "w", encoding="utf-8") as fh:
        json.dump({"summary": summary, "samples": results}, fh, indent=2)
    ckpt_vol.commit()

    return summary


@app.local_entrypoint()
def main():
    try:
        # Re-upload eval inputs from the workspace. Each stage runs in a fresh
        # per-experiment env whose volumes were cascade-deleted by the
        # previous stage's teardown. `remote_path` is a volume-root path; the
        # ckpt volume mounts at /ckpts and the data volume mounts at /data,
        # so volume-root /final is /ckpts/final at read time and volume-root
        # /val.jsonl is /data/val.jsonl. Without the adapter re-upload,
        # eval_fn() silently falls back to the base model (Path check at
        # /ckpts/final misses).
        for vol, local_rel, remote_path in [
            (DATA_VOLUME, "data/val.jsonl",   "/val.jsonl"),
            (CKPT_VOLUME, "artifacts/final",  "/final"),
        ]:
            if (Path(".") / local_rel).exists():
                uploaded = lifecycle.upload_to_volume(
                    EXP_ID, vol, local_rel, remote_path,
                )
                print(f"uploaded {uploaded['src']} -> {uploaded['volume']}{uploaded['remote']}")

        summary = eval_fn.remote()
        print(json.dumps(summary, indent=2))
        print()
        print("pulling eval results ...")
        pulled = lifecycle.pull_all(EXP_ID)
        print(f"pulled {len(pulled['pulled'])} items")
    finally:
        try:
            result = lifecycle.teardown(EXP_ID)
            print(f"teardown: {result}")
        except RuntimeError as exc:
            print(f"teardown skipped: {exc}", file=sys.stderr)
