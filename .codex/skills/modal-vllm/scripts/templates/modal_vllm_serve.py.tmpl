"""vLLM serving on Modal — generated by the modal-vllm skill.

Generated for experiment: ${EXP_ID}

Deploy:
    modal deploy --env=neurico-${EXP_ID} <this file>

Capture endpoint (after deploy):
    python <this file> capture-endpoint

Use endpoint URL + proxy tokens from .neurico/modal_endpoint.json in
experiment code. Teardown when done:
    python .claude/skills/modal-vllm/scripts/lifecycle.py teardown \\
        --exp-id ${EXP_ID}
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

import modal

# --------------------------------------------------------------------------- #
# Skill-provided lifecycle                                                    #
# --------------------------------------------------------------------------- #

# lifecycle.py only exists in the local workspace; if the import fails we're
# inside the Modal container. See modal-training/lora-train for the rationale.

EXP_ID            = "${EXP_ID}"
APP_NAME          = "${APP_NAME}"
HF_VOLUME         = "${HF_VOLUME}"
VLLM_CACHE_VOLUME = "${VLLM_CACHE_VOLUME}"

# Discover lifecycle.py by walking UP from this file's own path, not from CWD.
# `Path(".claude/skills/...")` resolves against the current working directory,
# so `python /abs/path/workspace/src/modal_serve.py capture-endpoint` from any
# other cwd would silently miss the skill directory, land in the except branch,
# and later NoneType-crash inside capture_endpoint(). Anchoring on __file__
# makes the lookup cwd-invariant. Inside the Modal container the walk finds
# nothing and we still fall through to lifecycle=None as intended.
try:
    _here = Path(__file__).resolve().parent
    _skill_scripts = None
    for _anc in [_here, *_here.parents]:
        _cand = _anc / ".claude" / "skills" / "modal-vllm" / "scripts"
        if (_cand / "lifecycle.py").exists():
            _skill_scripts = _cand
            break
    if _skill_scripts is None:
        raise ImportError(
            "modal-vllm/scripts/lifecycle.py not found under any ancestor of "
            + str(_here)
        )
    sys.path.insert(0, str(_skill_scripts))
    import lifecycle  # noqa: E402
except ImportError:
    lifecycle = None  # type: ignore[assignment]

# Both `modal deploy <file>` and `python <file> capture-endpoint` import this
# module. Only the deploy path should (re-)mint the per-experiment env; the
# capture-endpoint path runs AFTER deploy to write the redacted endpoint JSON
# and must not flip the sentinel's pull_complete back to False mid-recovery.
_IS_CAPTURE_ENDPOINT = len(sys.argv) > 1 and sys.argv[1] == "capture-endpoint"

if lifecycle is not None and not _IS_CAPTURE_ENDPOINT:
    # vLLM's reproducibility artifact is the redacted endpoint JSON, which
    # the vllm lifecycle's pull_all() handles directly from a workspace-local
    # file (.neurico/modal_endpoint.json). No volume-side manifest entries
    # are needed for the default serving case; add entries here if your
    # endpoint writes log artifacts to a Modal volume you want pulled back.
    lifecycle.register(
        EXP_ID,
        app_name=APP_NAME,
        volumes=[HF_VOLUME, VLLM_CACHE_VOLUME],
        required_secrets=${REQUIRED_SECRETS},
        pull_manifest=[],
        share_hf_cache=${SHARE_HF_CACHE},
    )

# --------------------------------------------------------------------------- #
# Modal app                                                                   #
# --------------------------------------------------------------------------- #

MODEL_NAME     = "${BASE_MODEL}"
MODEL_REVISION = "${BASE_MODEL_REVISION}"
LORA_REPO      = "${LORA_REPO}"
LORA_NAME      = "experiment-adapter"
VLLM_PORT      = 8000
MINUTES        = 60

vllm_image = (
    modal.Image.from_registry("nvidia/cuda:12.9.0-devel-ubuntu22.04",
                              add_python="3.12")
    .entrypoint([])
    .uv_pip_install("vllm==0.21.0", "huggingface_hub[hf_transfer]")
    .env({
        "HF_XET_HIGH_PERFORMANCE": "1",
        "VLLM_LOG_STATS_INTERVAL": "5",
    })
)

hf_cache_vol   = modal.Volume.from_name(HF_VOLUME,         create_if_missing=True)
vllm_cache_vol = modal.Volume.from_name(VLLM_CACHE_VOLUME, create_if_missing=True)

app = modal.App(APP_NAME)


@app.function(
    image=vllm_image,
    gpu="${GPU}",
    scaledown_window=${SCALEDOWN_MINUTES} * MINUTES,
    timeout=15 * MINUTES,
    min_containers=0,
    secrets=${SECRETS_LIST},
    volumes={
        "/root/.cache/huggingface": hf_cache_vol,
        "/root/.cache/vllm":        vllm_cache_vol,
    },
)
@modal.concurrent(max_inputs=16)
@modal.web_server(
    port=VLLM_PORT,
    startup_timeout=15 * MINUTES,
    requires_proxy_auth=True,
)
def serve():
    cmd = [
        "vllm", "serve", MODEL_NAME,
        "--revision", MODEL_REVISION,
        "--served-model-name", MODEL_NAME, "llm",
        "--host", "0.0.0.0",
        "--port", str(VLLM_PORT),
        "--max-model-len", "${MAX_MODEL_LEN}",
        "--gpu-memory-utilization", "0.92",
    ]
    if LORA_REPO:
        cmd += [
            "--enable-lora",
            "--max-lora-rank", "${MAX_LORA_RANK}",
            "--lora-modules", f"{LORA_NAME}={LORA_REPO}",
        ]
    subprocess.Popen(cmd)


# --------------------------------------------------------------------------- #
# Local helpers                                                               #
# --------------------------------------------------------------------------- #

def _derive_url() -> str:
    """
    Look up the deployed function's actual web URL via the Modal Python SDK.

    `modal app list --json` doesn't include URLs and the `app describe` /
    `app show` commands don't exist on Modal CLI >=1.4. Synthesizing the URL
    from a fixed pattern (`https://{ws}--{APP_NAME}-serve.modal.run`) gets it
    wrong for env-scoped apps, which carry a hash suffix Modal assigns at
    deploy time. The SDK's Function.hydrate() / get_web_url() returns the
    real URL the deploy printed.

    Honors MODAL_ENDPOINT_URL as an override for offline/scripted use where
    the SDK lookup can't reach Modal's API.
    """
    override = os.environ.get("MODAL_ENDPOINT_URL", "").strip()
    if override:
        return override

    env = f"neurico-{EXP_ID}"
    try:
        fn = modal.Function.from_name(
            APP_NAME, "serve", environment_name=env,
        )
        fn.hydrate()
        url = fn.get_web_url()
        if url:
            return url
    except Exception as exc:
        # Fall through to synthesis with a clear note for the user.
        print(
            f"warn: SDK lookup of {APP_NAME!r}/serve in {env!r} failed: "
            f"{type(exc).__name__}: {exc}; falling back to URL synthesis",
            file=sys.stderr,
        )

    pr = subprocess.run(["modal", "profile", "current"],
                        capture_output=True, text=True, timeout=10)
    workspace = pr.stdout.strip().split("\n")[0].strip()
    if not workspace:
        raise RuntimeError(
            "could not derive workspace from `modal profile current` and "
            f"SDK lookup of {APP_NAME!r}/serve in {env!r} returned no URL. "
            f"Pass MODAL_ENDPOINT_URL=<url> from the deploy output."
        )
    return f"https://{workspace}--{APP_NAME}-serve.modal.run"


def capture_endpoint():
    """After `modal deploy`, mint proxy-auth tokens and write the endpoint JSON.

    Reads `MODAL_KEY` / `MODAL_SECRET` from env if provided; otherwise prints
    instructions for the user to create them in the Modal dashboard.
    """
    url = _derive_url()
    key    = os.environ.get("MODAL_KEY", "")
    secret = os.environ.get("MODAL_SECRET", "")
    if not (key and secret):
        print()
        print("=" * 60)
        print(f"Endpoint URL: {url}")
        print()
        print("Create a proxy-auth token in the Modal dashboard:")
        print("  Settings -> Proxy Auth Tokens -> Create")
        print()
        print("Then re-run with:")
        print("  MODAL_KEY=wk-... MODAL_SECRET=ws-... \\")
        print(f"    python {sys.argv[0]} capture-endpoint")
        return 1

    written = lifecycle.capture_endpoint(
        exp_id=EXP_ID,
        url=url,
        key=key,
        secret=secret,
        base_model=MODEL_NAME,
        base_model_revision=MODEL_REVISION,
        lora_repo=LORA_REPO,
        vllm_flags={
            "max_model_len": ${MAX_MODEL_LEN},
            "max_lora_rank": ${MAX_LORA_RANK},
            "scaledown_minutes": ${SCALEDOWN_MINUTES},
        },
    )
    print(f"wrote {written}")
    print(f"experiment code can now read it via: "
          f"json.load(open('{written}'))")
    return 0


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "capture-endpoint":
        sys.exit(capture_endpoint())
    print(__doc__)
    sys.exit(0)
